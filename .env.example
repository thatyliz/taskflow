# ─── Aplicação ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=debug

# ─── Banco de Dados ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskuser
DB_PASSWORD=taskpass
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT_MS=5000

# ─── Simulação de Falhas (usar apenas em dev/test) ────────────
# FAILURE_MODE=latency        # injeta latência artificial
# FAILURE_MODE=db_error       # simula erro de banco
# FAILURE_MODE=panic          # simula crash da aplicação
# FAILURE_RATE=0.3            # percentual de falhas (0.0 – 1.0)
